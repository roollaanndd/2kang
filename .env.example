# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase (REQUIRED) ────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# ── Admin seed passwords (override defaults) ───────────────────────────────────
# Set these in your CI/CD secrets (Vercel env vars), NOT here.
# The fallback defaults in AuthContext are for local dev only — change on first login.
VITE_ADMIN_DEFAULT_PASSWORD=change-me-immediately
VITE_OWNER_DEFAULT_PASSWORD=change-me-immediately

# ── API endpoint ───────────────────────────────────────────────────────────────
VITE_API_URL=https://api.omdc.id

# ── Feature flags ──────────────────────────────────────────────────────────────
# VITE_ENABLE_KIOSK=true
# VITE_ENABLE_MOBILE_APP=true
