# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# API endpoint for the OMDC backend (leave empty to use mock data)
VITE_API_URL=https://api.omdc.id

# Override default admin seed passwords (set in CI/CD secrets, not here)
VITE_ADMIN_DEFAULT_PASSWORD=change-me-immediately
VITE_OWNER_DEFAULT_PASSWORD=change-me-immediately

# Feature flags
# VITE_ENABLE_KIOSK=true
# VITE_ENABLE_MOBILE_APP=true
